PORT=3000

# Salesforce "LMV" External Client App. Not used by this backend anymore -
# DM login now happens on-device via Authorization Code + PKCE (see the
# Flutter app's AuthService/SalesforceOAuthConfig, which needs the same
# CLIENT_ID passed in as --dart-define=SF_CLIENT_ID=...). Kept here only as
# a reference so both sides of the integration are documented in one place.
CLIENT_ID=
CLIENT_SECRET=

# ADN SMS (https://portal.adnsms.com)
ADN_APP_URL=
ADN_API_KEY=
ADN_API_SECRET=

# Salesforce object/field API names for the Learner Verification feature,
# confirmed against scripts/objects.json.
SF_LEARNER_OBJECT=Apprenticeship_Learner__c
SF_LEARNER_NAME_FIELD=Name
SF_LEARNER_GENDER_FIELD=Learner_Gender__c
SF_LEARNER_PHONE_FIELD=Learner_Mobile_Number__c
SF_LEARNER_STATUS_FIELD=Verification_Status__c
SF_LEARNER_BRANCH_FIELD=Master_Branch__c
SF_LEARNER_PVC_CODE_FIELD=PVC__c
SF_LEARNER_SELECTION_FIELD=Selection__c
SF_LEARNER_COHORT_NAME_FIELD=Cohort_Name__c

SF_BRANCH_OBJECT=Master_Branch__c
SF_BRANCH_NAME_FIELD=Name

# The target cohort filter lives in config/filters.js, not here - edit that
# file directly to change it.
